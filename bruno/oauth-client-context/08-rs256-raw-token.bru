meta {
  name: RS256 Raw Token
  type: http
  seq: 8
}

get {
  url: {{base_url}}/test-rs
  body: none
  auth: none
}

headers {
  Accept: application/json
  apikey: {{apikey_c1}}
  Authorization: {{incoming_jwt_token}}
