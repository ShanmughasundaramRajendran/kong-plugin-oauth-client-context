meta {
  name: Billing ES256 C2 V5
  type: http
  seq: 4
}

get {
  url: {{base_url}}/billing/es
  body: none
  auth: none
}

headers {
  Accept: application/json
  apikey: {{apikey_c2}}
  Authorization: Bearer {{incoming_jwt_token}}
