meta {
  name: RS256 C1 V5
  type: http
  seq: 1
}

get {
  url: {{base_url}}/test-rs
  body: none
  auth: none
}

headers {
  Accept: application/json
  apikey: {{apikey_c1}}
  Authorization: Bearer {{incoming_jwt_token}}
  x-consumer-extra-claim: {{header_include}}
  x-consumer-replace-claim: {{header_replace}}
  x-consumer-ignore-claim: {{header_ignore}}
}
